# ─────────────────────────────────────────────
# CODEX ACADEMY — Environment Variables
# Copy this to .env.local and fill in your values
# ─────────────────────────────────────────────

# SUPABASE
# Get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose this client-side

# STRIPE
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...                      # Use sk_test_... for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...     # Use pk_test_... for development
STRIPE_WEBHOOK_SECRET=whsec_...                    # From Stripe → Webhooks → Signing secret

# Stripe Price IDs — create these in Stripe Dashboard → Products
STRIPE_LEARNER_MONTHLY_PRICE_ID=price_...
STRIPE_LEARNER_ANNUAL_PRICE_ID=price_...
STRIPE_ELITE_MONTHLY_PRICE_ID=price_...
STRIPE_ELITE_ANNUAL_PRICE_ID=price_...

# ANTHROPIC (Claude AI Tutor)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# APP
NEXT_PUBLIC_APP_URL=http://localhost:3000          # Change to your domain in production
NEXT_PUBLIC_APP_NAME=Codex Academy
